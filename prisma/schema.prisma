generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  phone     String?
  email     String?
  role      String   // "ADMIN", "MANAGER", "EXAMINER"
  isActive   Boolean  @default(true)
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  assignments TestAssignment[]
}

model Student {
  id          Int      @id @default(autoincrement())
  cccd        String   @unique
  name        String
  dob         String?
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])
  testResults TestResult[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isCompleted Boolean  @default(false)
  students    Student[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VehicleType {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  seats       Int?
  brand       String?
  owner       String?
  manufacturingYear Int?
  inspectionExpiry  DateTime?
  contractStart DateTime?
  contractEnd   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TestType {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  criteria    Criterion[]
  assignments TestAssignment[]
  testResults TestResult[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Criterion {
  id             Int      @id @default(autoincrement())
  name           String
  pointsToDeduct Int      @default(5)
  testTypeId     Int
  testType       TestType @relation(fields: [testTypeId], references: [id])
  scores         Score[]
}

model TestAssignment {
  id          Int      @id @default(autoincrement())
  examinerId  Int
  examiner    User     @relation(fields: [examinerId], references: [id])
  testTypeId  Int
  testType    TestType @relation(fields: [testTypeId], references: [id])
  courseId    Int?
}

model TestResult {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  testTypeId  Int
  testType    TestType @relation(fields: [testTypeId], references: [id])
  totalScore  Int      @default(100)
  status      String   @default("PENDING") // PENDING, PASSED, FAILED
  scores      Score[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, testTypeId])
}

model Score {
  id             Int        @id @default(autoincrement())
  testResultId   Int
  testResult     TestResult @relation(fields: [testResultId], references: [id])
  criterionId    Int
  criterion      Criterion  @relation(fields: [criterionId], references: [id])
  timesDeducted  Int        @default(1)
  createdAt      DateTime   @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
