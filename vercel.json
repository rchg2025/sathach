{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebook|zalo|twitter|linkedin|whatsapp|skype|telegram|discord|slack).*"
        }
      ],
      "destination": "/api/seo"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/manager/cron/check-vehicles",
      "schedule": "0 1 * * *"
    }
  ]
}
